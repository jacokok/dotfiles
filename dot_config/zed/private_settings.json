{
  "context_servers": {
    "svelte-mcp": {
      "enabled": true,
      "settings": {},
    },
  },
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_size": 22.0,
  "ui_font_size": 22.0,
  "ui_font_family": "Adwaita Sans",
  "theme": "Catppuccin Mocha",
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "tab_size": 2,
  "colorize_brackets": true,
  "middle_click_paste": false,
  "agent_buffer_font_size": 20,
  "agent_ui_font_size": 20,
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right",
  },
  "minimap": {
    "show": "auto",
  },
  "gutter": {
    // "runnables": false,
    "min_line_number_digits": 3,
    "folds": false,
  },
  "outline_panel": {
    "dock": "right",
    "button": false,
  },
  "collaboration_panel": {
    "button": false,
    "dock": "right",
  },
  "tab_bar": {
    "show_nav_history_buttons": false,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors",
  },
  "git": {
    "inline_blame": {
      "enabled": false,
    },
  },
  "project_panel": {
    "dock": "right",
    "folder_icons": false,
    "default_width": 350,
  },
  "search": {
    "button": false,
  },
  "terminal": {
    "button": false,
  },
  "title_bar": {
    "show_sign_in": false,
  },
  "theme_overrides": {
    "Catppuccin Mocha": {
      "search.active_match_background": "#f38ba866",
      // "accents": [
      //   "#cbb0f766",
      //   "#b9c3fc66",
      //   "#86caee66",
      //   "#aee1b266",
      //   "#f0e0bd66",
      //   "#f1ba9d66",
      //   "#eb9ab766",
      // ],
    },
  },
  "features": {
    "edit_prediction_provider": "copilot",
  },
  "extend_comment_on_newline": false,
  "file_types": {
    "XML": [
      "*.csproj",
      "*.slnx",
      "Directory.Build.props",
      "Directory.Packages.props",
    ],
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "grok-code-fast-1",
    },
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "gpt-4.1",
      },
      {
        "provider": "copilot_chat",
        "model": "oswe-vscode-prime",
      },
      {
        "provider": "z.ai",
        "model": "GLM-4.7",
      },
    ],
    "always_allow_tool_actions": true,
    "play_sound_when_agent_done": true,
    "enable_feedback": false,
    "default_profile": "write",
    "agents_panel_dock": "right",
    "dock": "right",
    "default_model": {
      "provider": "z.ai",
      "model": "GLM-4.7",
    },
  },
  // "agent_servers": {
  //   "": {
  //     "command": "opencode",
  //     "args": ["acp"]
  //   }
  // }
  "languages": {
    "XML": {
      "format_on_save": "off",
    },
  },
  "ssh_connections": [
